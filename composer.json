{
  "name": "brs/backup-restore-system",
  "description": "XAMPP Backup & Restore System",
  "type": "project",
  "require": {
    "aws/aws-sdk-php": "^3.0",
    "google/apiclient": "^2.15",
    "phpseclib/phpseclib": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "classmap": ["lib/"]
  },
  "autoload-dev": {
    "classmap": ["tests/"]
  },
  "config": {
    "allow-plugins": {
      "google/apiclient-services": true
    }
  }
}
